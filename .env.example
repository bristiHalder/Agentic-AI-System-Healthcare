# API Keys for Kerala Ayurveda RAG System
# Add multiple Gemini keys for automatic rotation when one hits quota limits.
# Keys are tried in order (1, 2, 3, ...). On a quota/rate-limit error the next key is used.

# Option A: Multiple numbered keys (recommended for production)
GOOGLE_API_KEY_1=your_first_google_api_key_here
GOOGLE_API_KEY_2=your_second_google_api_key_here
GOOGLE_API_KEY_3=your_third_google_api_key_here

# Option B: Single key fallback (used if no numbered keys are found)
# GOOGLE_API_KEY=your_google_api_key_here

# Get free API keys at: https://aistudio.google.com/app/apikey